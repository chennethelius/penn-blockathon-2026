TRONGRID_API_KEY=your_trongrid_api_key
TRONGRID_BASE_URL=https://api.trongrid.io
TRONSCAN_BASE_URL=https://apilist.tronscanapi.com/api
JUSTLEND_API_URL=https://api.justlend.org
SUNSWAP_API_URL=https://api.sunswap.com

REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql://user:pass@localhost:5432/trontrust

MODEL_PATH=models/anubis_v1.json
RETRAIN_THRESHOLD=1000

SENTINEL_CHECK_INTERVAL_SECONDS=30
SENTINEL_ENERGY_DRAIN_THRESHOLD=10
SENTINEL_FAKE_USDT_CHECK=true

LOG_LEVEL=INFO
ENV=development
